# =============================================================================
# Render Environment Variables - Import this file in Render Dashboard
# Go to Service → Environment → "Import from .env"
# =============================================================================

# Application Settings
NODE_ENV=production
PORT=10000
FRONTEND_URL=http://localhost:3000

# Database (Replace with your actual Render PostgreSQL Internal URL)
DATABASE_URL=postgresql://beleqet_user:4bIHyQh2HIzWOa4LJccyk3A6pXnHC9N0@dpg-d94nak57vvec73drsre0-a/beleqet_db_bt7z

# Redis (Optional - set if you have Redis instance)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# JWT Authentication (Required)
JWT_ACCESS_SECRET=docker_default_secret_please_change_in_production_use_openssl_rand_hex_64
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# OpenAI (Optional - for AI features)
OPENAI_API_KEY=sk-dummy-key-not-configured
OPENAI_MODEL=gpt-4o-mini

# Telegram Bot (Optional - for notifications)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz1234567890
TELEGRAM_CHANNEL_ID=-1001234567890

# Chapa Payment Gateway (Optional - for payments)
CHAPA_SECRET_KEY=CHASECK_TEST-dummy
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-dummy
CHAPA_WEBHOOK_SECRET=dummy-webhook-secret
CHAPA_CALLBACK_URL=http://localhost:10000/api/v1/escrow/callback
CHAPA_RETURN_URL=http://localhost:3000/freelance/payment-success

# AWS S3 (Optional - for file uploads)
AWS_S3_BUCKET=beleqet-uploads-dummy
AWS_ACCESS_KEY_ID=dummy-access-key
AWS_SECRET_ACCESS_KEY=dummy-secret-key
AWS_REGION=us-east-1

# Email/SMTP (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dummy@example.com
SMTP_PASS=dummy-password
EMAIL_FROM=Beleqet <noreply@beleqet.com>

# Bull Board (Job Queue Dashboard)
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=admin123
